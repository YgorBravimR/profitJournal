{
	"name": "axion-video",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"preview": "remotion preview src/index.tsx --port 4010",
		"render": "remotion render src/index.tsx DemoVideo --output ../demo-videos/axion-final.mp4 --codec h264",
		"render:hd": "remotion render src/index.tsx DemoVideo --output ../demo-videos/axion-final-hd.mp4 --codec h264 --width 1920 --height 1080"
	},
	"dependencies": {
		"@remotion/cli": "^4.0.0",
		"@remotion/player": "^4.0.0",
		"remotion": "^4.0.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"typescript": "^5.0.0",
		"@types/react": "^19.0.0"
	}
}
